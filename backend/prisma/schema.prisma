generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SuiteType {
  EDUCATION_SUITE
  VMETRON_SUITE
}

enum ProductType {
  VIDYALUMA
  VAANMEET
  VFORMIX
  VMETRON
  SUPPORT
  CUSTOMER_PORTAL
  CLIENT_PORTAL
  BILLING
  REPORTS
  COMMUNICATION
  PROMOTIONS
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum VaanForgeRunStatus {
  pending
  analyzing
  planned
  failed
  completed
}

enum VaanForgeOutputType {
  product_requirement_document
  architecture_plan
  folder_structure
  database_plan
  api_plan
  ui_screen_list
  sprint_roadmap
  codex_implementation_prompt
}

enum AgentExecutionStatus {
  pending
  preparing
  generating
  validating
  repairing
  completed
  blocked
  failed
}

enum AgentTaskStatus {
  pending
  preparing
  generating
  validating
  repairing
  completed
  blocked
  failed
}

enum AgentFileStatus {
  planned
  written
  skipped
  blocked
}

enum AgentValidationStatus {
  passed
  failed
  skipped
}

enum AgentErrorStatus {
  open
  repaired
  blocked
}

enum AgentRepairStatus {
  attempted
  succeeded
  failed
}

enum AgentTemplateStatus {
  draft
  pending_review
  published
  unpublished
  archived
}

enum AgentTemplateReleaseStatus {
  draft
  approved
  rejected
  released
  rolled_back
}

enum AgentTemplateQualityStatus {
  passed
  failed
  pending
}

enum VFormixAgentStatus {
  pending
  mapping
  validating
  template_matched
  blueprint_generated
  approval_required
  coding_started
  completed
  failed
  blocked
}

enum VFormixAgentConfigStatus {
  draft
  active
  paused
}

enum VFormixAgentTriggerType {
  submission
  manual
  approval
  template_selection
}

enum VFormixAgentWebhookStatus {
  accepted
  rejected
  failed
}

enum AgentLiveSessionStatus {
  open
  closed
}

enum AgentWorkspaceControlStatus {
  accepted
  rejected
}

enum AgentStepApprovalDecision {
  approved
  rejected
}

enum AgentTeamStatus {
  created
  assigned
  in_progress
  review_required
  approved
  handed_off
  completed
  blocked
  failed
}

enum AgentRoleStatus {
  active
  inactive
}

enum AgentConflictStatus {
  open
  resolved
}

enum AgentReviewDecision {
  approved
  rejected
  changes_requested
}

enum AgentFinalReviewDecision {
  approved
  rejected
}

enum AgentDeploymentStatus {
  draft
  preparing
  ready
  deploying
  verifying
  live
  failed
  rollback_required
  rolled_back
}

enum AgentDeploymentTargetType {
  AWS_EC2
  S3_CLOUDFRONT
  DOCKER_SERVER
  VERCEL
  VMNEXUS_CLOUD
}

enum AgentDeploymentCheckStatus {
  passed
  failed
  blocked
}

enum AgentDeploymentLogLevel {
  info
  warning
  error
}

enum AgentDeploymentEnvironment {
  staging
  production
}

enum AgentReleaseMigrationStatus {
  pending
  applied
  failed
}

enum AgentReleaseBuildStatus {
  pending
  passed
  failed
}

enum AgentRollbackStatus {
  requested
  completed
  failed
}

enum AgentDeploymentHealthStatus {
  healthy
  unhealthy
}

enum AgentMemoryStatus {
  pending_review
  approved
  rejected
  archived
}

enum AgentMemoryTrust {
  trusted
  untrusted
}

enum AgentMemoryType {
  project
  user_preference
  product
  error_fix
  template_usage
  deployment
  approval
}

enum AgentMemorySourceType {
  project
  error
  fix
  template
  deployment
  approval
  manual
}

enum AgentKnowledgeType {
  project_pattern
  architecture
  common_error
  verified_fix
  deployment_lesson
  security_rule
  design_rule
}

enum BuilderProjectStatus {
  draft
  requirements_submitted
  blueprint_ready
  blueprint_approved
  blueprint_rejected
  coding_started
  change_requested
  delivered
  blocked
  failed
}

enum BuilderRequirementStatus {
  submitted
  accepted
  blocked
}

enum BuilderBlueprintStatus {
  generated
  approved
  rejected
  superseded
}

enum BuilderOutputStatus {
  pending
  in_progress
  ready
  failed
}

enum BuilderChangeRequestStatus {
  requested
  accepted
  in_progress
  completed
  rejected
}

enum BuilderBillingPlanTier {
  free_trial
  starter
  pro
  business
  enterprise
  custom
}

enum BuilderBillingCycle {
  MONTHLY
  YEARLY
}

enum CustomerSubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  expired
}

enum CustomerInvoiceStatus {
  draft
  issued
  paid
  failed
  void
}

enum CustomerPaymentStatus {
  created
  paid
  failed
  refunded
}

enum CustomerUsageMetric {
  agent_run
  template_use
  build_minute
  ai_credit
  storage_mb
  deployment
  team_member
  regeneration
}

enum CustomerUsageEventStatus {
  accepted
  rejected
  refunded
}

enum CustomerCreditTransactionType {
  grant
  deduct
  refund
  topup
  adjustment
}

enum OperationsIncidentSeverity {
  SEV1
  SEV2
  SEV3
  SEV4
}

enum OperationsIncidentStatus {
  open
  investigating
  mitigated
  resolved
  postmortem
}

enum OperationsCommandAction {
  pause_deployments
  pause_agent_generation
  emergency_stop
  resume_services
  maintenance_mode
  scheduled_maintenance
  restart_agent
  drain_agent
  enable_agent
  disable_agent
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String
  passwordHash   String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  role           String        @default("Founder")
  passwordResetTokens PasswordResetToken[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id            String                     @id @default(cuid())
  name          String
  suiteType     SuiteType
  users         User[]
  roles         Role[]
  workspaces    Workspace[]
  subscription  OrganizationSubscription?
  subscriptions Subscription[]
  entitlements  ProductEntitlement[]
  usageRecords  UsageRecord[]
  notifications Notification[]
  revenues      Revenue[]
  expenses      Expense[]
  payments      Payment[]
  invoices      Invoice[]
  reportExports ReportExport[]
  projects      Project[]
  tasks         Task[]
  clients       Client[]
  deals         Deal[]
  leads         Lead[]
  customers     Customer[]
  supportTickets SupportTicket[]
  departments    Department[]
  employees      Employee[]
  candidates     Candidate[]
  interviews     Interview[]
  offers         Offer[]
  approvals      Approval[]
  agreements     Agreement[]
  complianceItems ComplianceItem[]
  governmentRegistrations GovernmentRegistration[]
  documents      Document[]
  creatorProfiles CreatorProfile[]
  campaigns       Campaign[]
  partners        Partner[]
  announcements   Announcement[]
  communications  Communication[]
  automationRules AutomationRule[]
  intelligenceSnapshots IntelligenceSnapshot[]
  vaanForgeRuns VaanForgeAgentRun[]
  vaanForgeOutputs VaanForgeOutput[]
  vaanForgeAuditLogs VaanForgeAuditLog[]
  agentExecutionRuns AgentExecutionRun[]
  agentTasks AgentTask[]
  agentFiles AgentFile[]
  agentValidationRuns AgentValidationRun[]
  agentErrors AgentError[]
  agentRepairAttempts AgentRepairAttempt[]
  agentCommits AgentCommit[]
  agentActivityLogs AgentActivityLog[]
  agentTemplates AgentTemplate[]
  agentTemplateVersions AgentTemplateVersion[]
  agentTemplateInputs AgentTemplateInput[]
  agentTemplateFiles AgentTemplateFile[]
  agentTemplateQualityChecks AgentTemplateQualityCheck[]
  agentTemplateUsageLogs AgentTemplateUsageLog[]
  agentTemplateReviews AgentTemplateReview[]
  vformixAgentConfigs VFormixAgentConfig[]
  vformixAgentFieldMappings VFormixAgentFieldMapping[]
  vformixAgentTriggers VFormixAgentTrigger[]
  vformixAgentSubmissionLinks VFormixAgentSubmissionLink[]
  vformixAgentMappingErrors VFormixAgentMappingError[]
  vformixAgentWebhookLogs VFormixAgentWebhookLog[]
  agentLiveSessions AgentLiveSession[]
  agentLiveEvents AgentLiveEvent[]
  agentWorkspaceInstructions AgentWorkspaceInstruction[]
  agentWorkspaceControls AgentWorkspaceControl[]
  agentWorkspaceEvidence AgentWorkspaceEvidence[]
  agentStepApprovals AgentStepApproval[]
  agentRoles AgentRole[]
  agentRoleConfigs AgentRoleConfig[]
  agentAssignments AgentAssignment[]
  agentHandoffs AgentHandoff[]
  agentComments AgentComment[]
  agentConflicts AgentConflict[]
  agentDecisionLogs AgentDecisionLog[]
  agentReviews AgentReview[]
  agentFinalReviews AgentFinalReview[]
  agentDeployments AgentDeployment[]
  agentDeploymentTargets AgentDeploymentTarget[]
  agentDeploymentChecks AgentDeploymentCheck[]
  agentDeploymentLogs AgentDeploymentLog[]
  agentDeploymentReleases AgentDeploymentRelease[]
  agentDeploymentRollbacks AgentDeploymentRollback[]
  agentDeploymentHealthChecks AgentDeploymentHealthCheck[]
  agentMemoryEntries AgentMemoryEntry[]
  agentMemorySources AgentMemorySource[]
  agentMemoryReviews AgentMemoryReview[]
  agentKnowledgeEntries AgentKnowledgeEntry[]
  agentKnowledgeTags AgentKnowledgeTag[]
  agentKnowledgeRetrievalLogs AgentKnowledgeRetrievalLog[]
  agentErrorFixPatterns AgentErrorFixPattern[]
  agentArchitecturePatterns AgentArchitecturePattern[]
  builderProjects BuilderProject[]
  builderProjectRequirements BuilderProjectRequirement[]
  builderProjectBlueprints BuilderProjectBlueprint[]
  builderProjectOutputs BuilderProjectOutput[]
  builderProjectChangeRequests BuilderProjectChangeRequest[]
  builderProjectActivityLogs BuilderProjectActivityLog[]
  billingPlans BuilderBillingPlan[]
  customerSubscriptions CustomerSubscription[]
  customerInvoices CustomerInvoice[]
  customerPayments CustomerPayment[]
  customerUsageLimits CustomerUsageLimit[]
  customerUsageEvents CustomerUsageEvent[]
  customerCreditWallets CustomerCreditWallet[]
  customerCreditTransactions CustomerCreditTransaction[]
  razorpayWebhookEvents RazorpayWebhookEvent[]
  launchWorkspaces LaunchWorkspace[]
  workspaceMembers WorkspaceMember[]
  workspaceInvites WorkspaceInvite[]
  workspaceRoles WorkspaceRole[]
  workspaceAuditLogs WorkspaceAuditLog[]
  securityEvents SecurityEvent[]
  reliabilityChecks ReliabilityCheck[]
  complianceRecords ComplianceRecord[]
  dataExportRequests DataExportRequest[]
  dataDeleteRequests DataDeleteRequest[]
  launchReadinessChecks LaunchReadinessCheck[]
  operationsIncidents OperationsIncident[]
  operationsAuditLogs OperationsAuditLog[]
  operationsHealthChecks OperationsHealthCheck[]
  operationsAgentMetrics OperationsAgentMetric[]
  operationsProductMetrics OperationsProductMetric[]
  operationsBusinessMetrics OperationsBusinessMetric[]
  maintenanceWindows MaintenanceWindow[]
  emergencyActions EmergencyAction[]
  settings        OrganizationSettings?
  auditLogs     AuditLog[]
  dailyNotes    DailyNote[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
}

model Workspace {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  suiteType       SuiteType
  name            String
  enabledProducts ProductType[]
  status          String       @default("ACTIVE")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  productType ProductType @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Role {
  id                String        @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  name              String
  dashboardView     String?
  allowedModules    Json?
  restrictedActions Json?
  permissions       Permission[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([organizationId, name])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Plan {
  id               String      @id
  suiteType        SuiteType
  name             String
  monthlyPrice     Int?
  yearlyPrice      Int?
  currency         String      @default("INR")
  includedProducts ProductType[]
  limits           Json
  features         Json
  isActive         Boolean     @default(true)
}

model OrganizationSubscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  organization   Organization       @relation(fields: [organizationId], references: [id])
  suiteType      SuiteType
  planId         String
  status         SubscriptionStatus
  startedAt      DateTime           @default(now())
  renewalDate    DateTime?
  trialEndsAt    DateTime?
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  planId         String
  status         SubscriptionStatus
  startedAt      DateTime           @default(now())
  renewalDate    DateTime?
  trialEndsAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Payment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoiceId      String?
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])
  provider       String
  providerRef    String?
  amount         Decimal
  currency       String       @default("INR")
  status         String
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Invoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  number         String
  amount         Decimal
  currency       String       @default("INR")
  status         String
  dueDate        DateTime?
  paidAt         DateTime?
  payments       Payment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, number])
}

model ProductEntitlement {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  productType    ProductType
  enabled        Boolean      @default(false)
  limits         Json
  usage          Json

  @@unique([organizationId, productType])
}

model UsageRecord {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  productType    ProductType
  featureKey     String
  usedCount      Int
  limitCount     Int?
  periodStart    DateTime
  periodEnd      DateTime
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  actorId        String
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  title          String
  message        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Revenue {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  source         String
  amount         Decimal
  receivedAt     DateTime
  product        String?
  createdAt      DateTime     @default(now())
}

model Expense {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  category       String
  amount         Decimal
  spentAt        DateTime
  vendor         String?
  createdAt      DateTime     @default(now())
}

model GSTRecord {
  id             String   @id @default(cuid())
  organizationId String
  revenueTotal   Decimal
  expenseTotal   Decimal
  gstPayable     Decimal
  formula        String
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())
}

model CashFlowRecord {
  id             String   @id @default(cuid())
  organizationId String
  cashIn         Decimal
  cashOut        Decimal
  netCashFlow    Decimal
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())
}

model PnLReport {
  id                  String   @id @default(cuid())
  organizationId      String
  revenueTotal        Decimal
  expenseTotal        Decimal
  grossProfit         Decimal
  profitMarginPercent Decimal
  periodStart         DateTime
  periodEnd           DateTime
  createdAt           DateTime @default(now())
}

model ReportExport {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  reportType     String
  format         String
  status         String
  fileName       String?
  mimeType       String?
  content        String?
  storageProvider String?
  storageKey      String?
  storageUrl      String?
  createdAt      DateTime     @default(now())
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  ownerId        String?
  dueDate        DateTime?
  tasks          Task[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  ownerId        String?
  dueDate        DateTime?
  priority       String
  status         String
  comments       Json?
  attachments    Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Lead {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  company        String?
  email          String?
  phone          String?
  source         String?
  stage          String
  expectedValue  Decimal?
  deals          Deal[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  company        String?
  email          String?
  status         String
  projects       Project[]
  deals          Deal[]
  invoices       Invoice[]
  documents      Document[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Deal {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id])
  leadId          String?
  lead            Lead?        @relation(fields: [leadId], references: [id])
  title           String
  stage           String
  value           Decimal?
  expectedCloseAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Customer {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  name           String
  email          String?
  activePlan     String?
  renewalDate    DateTime?
  invoices       Invoice[]
  supportTickets SupportTicket[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model SupportTicket {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  customerId     String?
  customer       Customer?       @relation(fields: [customerId], references: [id])
  subject        String
  priority       String
  status         String
  messages       TicketMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  authorId  String?
  message   String
  internal  Boolean       @default(false)
  createdAt DateTime      @default(now())
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  leadId         String?
  employees      Employee[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Employee {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  name           String
  email          String
  role           String
  status         String
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Candidate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String?
  roleApplied    String
  stage          String
  source         String?
  interviews     Interview[]
  offers         Offer[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Interview {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  candidateId    String
  candidate      Candidate    @relation(fields: [candidateId], references: [id])
  round          String
  scheduledAt    DateTime
  interviewerId  String?
  status         String
  vaanMeetLink   String?
  score          Int?
  feedback       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Approval {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  entityType     String
  entityId       String?
  title          String
  status         String
  requestedById  String?
  approvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Offer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  candidateId    String
  candidate      Candidate    @relation(fields: [candidateId], references: [id])
  title          String
  status         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Agreement {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String
  title          String
  partyName      String?
  status         String
  expiresAt      DateTime?
  disclaimer     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ComplianceItem {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  category       String
  dueDate        DateTime
  status         String
  ownerId        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GovernmentRegistration {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  type            String
  title           String
  status          String
  referenceNumber String?
  dueDate         DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Document {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  title          String
  folder         String?
  tags           Json?
  version        Int          @default(1)
  expiresAt      DateTime?
  storageKey     String?
  mimeType       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model CreatorProfile {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  niche          String?
  payoutStatus   String?
